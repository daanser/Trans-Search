# ── 必填 ──────────────────────────────────────────
OPENAI_API_KEY=你的APIKey

# 管理接口鉴权 Key（自己随机生成一个长字符串，建议 32 位以上）
# 生成方法：python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=你自己生成的随机字符串

# ── 可选 ──────────────────────────────────────────
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
OPENAI_EMBED_MODEL=embedding-3
EMBED_DIM=2048
CHAT_MODEL=glm-4.7-flash

# 允许的前端域名（逗号分隔），生产环境改为实际域名
# 示例：https://search.transhelper.org,http://localhost
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# 生产环境设为 production 可关闭 /docs 接口文档
ENV=development

QDRANT_HOST=localhost
QDRANT_PORT=6333
